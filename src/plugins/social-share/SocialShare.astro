---
/**
 * SocialShare.astro — Plugin Social Share
 *
 * Renderiza título + botões de compartilhamento com URLs funcionais.
 * Lê configurações de pluginsConfig.socialShare.
 */
import { readDataAsync } from '../../lib/readData';

interface Props {
  title?: string;
  context?: 'post-bottom' | 'author-box';
}

const { title = '', context = 'post-bottom' } = Astro.props;

const pluginsConfig = await readDataAsync('pluginsConfig.json', {}) as any;
const shareConfig = pluginsConfig?.socialShare;
const enabled = shareConfig?.enabled !== false;
const style = shareConfig?.style || 'icon';
const sectionTitle: string = shareConfig?.sectionTitle || 'Compartilhe nas redes sociais';
const platforms: string[] = shareConfig?.platforms || [
  'facebook', 'twitter', 'whatsapp', 'linkedin', 'telegram', 'copy'
];

const platformDefs: Record<string, { icon: string; label: string }> = {
  facebook: {
    label: 'Facebook',
    icon: '<svg viewBox="0 0 24 24" role="img" focusable="false"><path fill="currentColor" d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.414c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.49 0-1.956.93-1.956 1.884v2.266h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073Z"/></svg>',
  },
  twitter: {
    label: 'Twitter/X',
    icon: '<svg viewBox="0 0 24 24" role="img" focusable="false"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.214-6.817-5.966 6.817H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/></svg>',
  },
  whatsapp: {
    label: 'WhatsApp',
    icon: '<svg viewBox="0 0 24 24" role="img" focusable="false"><path fill="currentColor" d="M20.52 3.49A11.86 11.86 0 0 0 12.05 0C5.46 0 .1 5.35.1 11.93c0 2.1.55 4.16 1.6 5.97L0 24l6.25-1.64a11.95 11.95 0 0 0 5.8 1.48h.01c6.59 0 11.95-5.35 11.95-11.93a11.86 11.86 0 0 0-3.49-8.42Zm-8.47 18.33h-.01c-1.74 0-3.45-.47-4.94-1.35l-.36-.21-3.7.97.99-3.61-.24-.37a9.88 9.88 0 0 1-1.52-5.32c0-5.46 4.44-9.9 9.91-9.9a9.86 9.86 0 0 1 7 2.9 9.84 9.84 0 0 1 2.9 7c0 5.46-4.45 9.89-9.91 9.89Zm5.43-7.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.47-.89-.79-1.49-1.76-1.66-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.61-.92-2.2-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.08 4.48.71.31 1.26.49 1.69.63.71.23 1.36.2 1.88.12.57-.09 1.76-.72 2.01-1.41.25-.69.25-1.28.17-1.41-.07-.13-.27-.2-.57-.35Z"/></svg>',
  },
  linkedin: {
    label: 'LinkedIn',
    icon: '<svg viewBox="0 0 24 24" role="img" focusable="false"><path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.049c.476-.9 1.637-1.85 3.37-1.85 3.602 0 4.267 2.371 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124Zm1.777 13.019H3.556V9h3.558v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/></svg>',
  },
  telegram: {
    label: 'Telegram',
    icon: '<svg viewBox="0 0 24 24" role="img" focusable="false"><path fill="currentColor" d="M9.78 15.65 9.4 21c.54 0 .77-.23 1.05-.51l2.52-2.41 5.22 3.82c.96.53 1.63.25 1.89-.88l3.43-16.07.01-.01c.3-1.42-.51-1.98-1.45-1.63L1.89 11.05c-1.38.54-1.36 1.32-.23 1.67l5.16 1.61L18.8 6.84c.56-.37 1.08-.17.66.2l-9.68 8.61Z"/></svg>',
  },
  pinterest: {
    label: 'Pinterest',
    icon: '<svg viewBox="0 0 24 24" role="img" focusable="false"><path fill="currentColor" d="M12.02 0C5.39 0 0 5.37 0 12c0 5.08 3.16 9.42 7.63 11.17-.1-.95-.2-2.41.04-3.45.22-.94 1.41-5.98 1.41-5.98s-.36-.72-.36-1.78c0-1.67.97-2.92 2.17-2.92 1.02 0 1.52.77 1.52 1.69 0 1.03-.66 2.57-1 3.99-.28 1.19.6 2.16 1.78 2.16 2.13 0 3.77-2.25 3.77-5.49 0-2.87-2.06-4.88-5.01-4.88-3.41 0-5.42 2.56-5.42 5.21 0 1.03.4 2.14.89 2.74.1.12.11.22.08.34-.09.38-.29 1.19-.33 1.36-.05.22-.17.27-.4.16-1.5-.7-2.44-2.9-2.44-4.67 0-3.8 2.76-7.29 7.96-7.29 4.18 0 7.43 2.98 7.43 6.96 0 4.16-2.62 7.5-6.26 7.5-1.22 0-2.37-.63-2.76-1.38l-.75 2.86c-.27 1.04-1.01 2.35-1.5 3.15A12.01 12.01 0 0 0 24 12c0-6.63-5.37-12-11.98-12Z"/></svg>',
  },
  copy: {
    label: 'Copiar',
    icon: '<svg viewBox="0 0 24 24" role="img" focusable="false"><path fill="currentColor" d="M16 1H4a2 2 0 0 0-2 2v12h2V3h12V1Zm3 4H8a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm0 16H8V7h11v14Z"/></svg>',
  },
};

const activePlatforms = platforms.filter(p => platformDefs[p]);
---

{enabled && activePlatforms.length > 0 && (
  <div class="walker-share-wrap" data-context={context}>
    {sectionTitle && (
      <p class="walker-share-title">{sectionTitle}</p>
    )}
    <ul
      class="social-icons list-unstyled list-inline mb-0 walker-share-list"
      data-style={style}
    >
      {activePlatforms.map(p => {
        const def = platformDefs[p];
        return (
          <li class="list-inline-item" data-platform={p}>
            <a href="#" class="walker-share-btn" aria-label={`Compartilhar no ${def.label}`} title={def.label}>
              <span class="share-icon" aria-hidden="true" set:html={def.icon} />
              {(style === 'label' || style === 'both') && (
                <span class="share-label ms-1">{def.label}</span>
              )}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
)}

<style>
  .walker-share-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }

  .walker-share-wrap[data-context="post-bottom"] {
    align-items: flex-end;
  }

  .walker-share-title {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8f9bac;
    margin: 0;
    line-height: 1;
  }

  .walker-share-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .walker-share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.35rem;
    min-height: 2.35rem;
    gap: 0.45rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--color-border-light, #eadfd8);
    border-radius: var(--radius-md, 8px);
    background: var(--color-bg-pure, #fff);
    color: var(--color-primary, #9f6f6a);
    box-shadow: var(--shadow-xs, 0 1px 2px rgba(60, 52, 49, 0.04));
    text-decoration: none;
    transition: transform var(--transition-fast, 200ms ease), border-color var(--transition-fast, 200ms ease), background var(--transition-fast, 200ms ease), color var(--transition-fast, 200ms ease);
  }

  [data-platform="facebook"] .walker-share-btn { color: #1877f2; }
  [data-platform="twitter"] .walker-share-btn { color: #000; }
  [data-platform="whatsapp"] .walker-share-btn { color: #25d366; }
  [data-platform="linkedin"] .walker-share-btn { color: #0a66c2; }
  [data-platform="telegram"] .walker-share-btn { color: #26a5e4; }
  [data-platform="pinterest"] .walker-share-btn { color: #e60023; }
  [data-platform="copy"] .walker-share-btn { color: #475569; }

  .walker-share-btn:hover {
    transform: translateY(-2px);
    border-color: currentColor;
    background: color-mix(in srgb, currentColor 9%, #fff);
  }

  .share-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.05rem;
    height: 1.05rem;
    min-width: 1.05rem;
    line-height: 1;
  }

  .share-icon :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .share-label {
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1;
    color: inherit;
  }

  .walker-share-list[data-style="label"] .share-icon {
    display: none;
  }
</style>

<script>
(function() {
  function initShareButtons() {
    var lists = document.querySelectorAll('.walker-share-list');
    lists.forEach(function(list) {
      var pageUrl = encodeURIComponent(window.location.href);
      var pageTitle = encodeURIComponent(document.title);
      var btns = list.querySelectorAll('.walker-share-btn');
      btns.forEach(function(btn) {
        var li = btn.closest('[data-platform]') as HTMLElement;
        var platform = li?.dataset.platform;
        if (!platform) return;

        var urls: Record<string, string> = {
          facebook:  'https://www.facebook.com/sharer/sharer.php?u=' + pageUrl,
          twitter:   'https://twitter.com/intent/tweet?url=' + pageUrl + '&text=' + pageTitle,
          whatsapp:  'https://wa.me/?text=' + pageTitle + '%20' + pageUrl,
          linkedin:  'https://www.linkedin.com/sharing/share-offsite/?url=' + pageUrl,
          telegram:  'https://t.me/share/url?url=' + pageUrl + '&text=' + pageTitle,
          pinterest: 'https://pinterest.com/pin/create/button/?url=' + pageUrl,
          copy:      'copy',
        };

        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var url = urls[platform!];
          if (url === 'copy') {
            navigator.clipboard?.writeText(window.location.href).then(function() {
              var label = (btn as HTMLElement).querySelector('.share-label');
              var icon = (btn as HTMLElement).querySelector('.share-icon');
              var original = label ? label.textContent : null;
              var originalIcon = icon ? icon.innerHTML : null;
              if (label) label.textContent = 'Copiado!';
              if (icon && !label) {
                icon.textContent = 'OK';
                setTimeout(function() { if (icon && originalIcon) icon.innerHTML = originalIcon; }, 2000);
              }
              setTimeout(function() { if (label) label.textContent = original; }, 2000);
            });
          } else {
            window.open(url, '_blank', 'noopener,width=600,height=450');
          }
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShareButtons);
  } else {
    initShareButtons();
  }
})();
</script>
