---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import PluginsHub from '../../components/admin/PluginsHub';
import { readDataAsync } from '../../lib/readData';
import { readStaticData } from '../../lib/staticData';

const dynamicRegistry = await readDataAsync<any[]>('pluginRegistry.json', []);
const staticRegistry = readStaticData<any[]>('pluginRegistry.json', []);
const dynamicByName = new Map(dynamicRegistry.map((plugin) => [plugin.name, plugin]));
const registry = staticRegistry.map((plugin) => ({ ...plugin, ...(dynamicByName.get(plugin.name) || {}) }));
---
<AdminLayout title="Plugins" activeSection="plugins">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900">Plugins</h1>
        <p class="text-slate-500 mt-1">Configure as integrações e funcionalidades extras do seu site.</p>
    </div>
    <PluginsHub registry={registry} client:load />
</AdminLayout>
