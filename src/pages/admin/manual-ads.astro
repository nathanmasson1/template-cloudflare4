---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import SettingsManualAds from '../../plugins/manual-ads/SettingsManualAds';
---
<AdminLayout title="Anuncios Manuais" activeSection="plugins">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900">Anuncios Manuais</h1>
        <p class="text-slate-500 mt-1">Configure banners laterais, blocos dentro dos posts e exit popup com imagens e links patrocinados.</p>
    </div>
    <SettingsManualAds client:load />
</AdminLayout>
