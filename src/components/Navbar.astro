---
import { readDataAsync } from '../lib/readData';

const site = await readDataAsync('siteConfig.json') || {};
const menu = await readDataAsync('menu.json') || {};
const navLinks = (menu.items && menu.items.length > 0) ? menu.items : [
  { href: '/', label: 'Home' },
  { href: '/blog/eventos', label: 'Eventos' },
  { href: '/blog/negocios', label: 'Negócios' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/contato', label: 'Contato' },
];

const siteName = site.name || 'Credencial Online';
const siteLogo = site.logo || '';
const logoMark = (site.logoMark || 'CO').toUpperCase();
const siteUrl = site.url || 'https://www.credencialonline.com.br/';
const ctaText = site.ctaText || 'Divulgar agora';
const navbarTopText = site.navbarTopText || 'Agenda e negocios';
const siteDomain = siteUrl.replace(/^https?:\/\//, '').replace(/\/$/, '');
const currentPath = Astro.url.pathname;
const formattedDate = new Date().toLocaleDateString('pt-BR', {
  weekday: 'long',
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<header class="navbar" id="navbar">
  <div class="navbar-top">
    <div class="container navbar-top-inner">
      <span class="navbar-top-live">{navbarTopText}</span>
      <span class="navbar-top-live">Agenda e negócios</span>
      <span>{formattedDate}</span>
      <a href={siteUrl} aria-label={`Acessar ${siteDomain}`}>{siteDomain}</a>
    </div>
  </div>

  <div class="navbar-masthead">
    <div class="container navbar-masthead-inner">
      <a href="/" class="navbar-logo" aria-label={siteName}>
        {siteLogo ? (
          <img
            src={siteLogo}
            alt={siteName}
            class="logo-image"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        ) : (
          <>
            <span class="logo-mark">{logoMark}</span>
            <span class="logo-text">{siteName}</span>
          </>
        )}
      </a>

      <a href="/contato" class="navbar-tip">{ctaText}</a>

      <button
        class="navbar-toggle"
        id="navToggle"
        aria-label="Abrir menu de navegação"
        aria-expanded="false"
      >
        <span class="hamburger"></span>
      </button>
    </div>
  </div>

  <nav class="navbar-nav" id="navMenu" aria-label="Menu principal">
    <div class="container">
      <ul class="navbar-links">
        {navLinks.map((link) => {
          const isActive = link.href === '/'
            ? currentPath === '/'
            : (currentPath === link.href || currentPath.startsWith(`${link.href}/`));
          return (
            <li>
              <a
                href={link.href}
                class:list={['navbar-link', { active: isActive }]}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow var(--transition-base), background var(--transition-base);
  }

  .navbar.scrolled {
    background: rgba(255, 255, 255, 0.99);
    box-shadow: var(--shadow-md);
  }

  .navbar-top {
    background: linear-gradient(90deg, var(--color-bg-dark), var(--color-primary) 52%, var(--color-accent));
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.72rem;
  }

  .navbar-top-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 30px;
    gap: var(--space-md);
  }

  .navbar-top-live {
    color: #fff;
    font-weight: var(--fw-extrabold);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
  }

  .navbar-top-live + .navbar-top-live {
    display: none;
  }

  .navbar-top a {
    justify-self: end;
    color: #fff2a8;
    font-weight: var(--fw-bold);
  }

  .navbar-masthead {
    border-bottom: 1px solid var(--color-border-light);
  }

  .navbar-masthead-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 68px;
    gap: var(--space-md);
  }

  .navbar-logo {
    grid-column: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    min-width: 0;
    text-decoration: none;
  }

  .logo-mark {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent-dark));
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 900;
    border-radius: var(--radius-sm);
    box-shadow: 8px 8px 0 var(--color-accent);
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 3.15rem);
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: 0;
    white-space: nowrap;
    line-height: 1;
  }

  .logo-image {
    height: 52px;
    max-width: min(330px, 58vw);
    width: auto;
    display: block;
  }

  .navbar-tip {
    justify-self: end;
    color: var(--color-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.55rem 0.85rem;
    font-size: var(--fs-xs);
    font-weight: var(--fw-extrabold);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }

  .navbar-tip:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  .navbar-nav {
    background: #fff;
  }

  .navbar-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    min-height: 44px;
    padding: 0;
    overflow-x: auto;
  }

  .navbar-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 0.45rem 0.8rem;
    font-size: var(--fs-xs);
    font-weight: var(--fw-extrabold);
    color: var(--color-text-secondary);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background var(--transition-fast);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
  }

  .navbar-link:hover,
  .navbar-link.active {
    color: #fff;
    background: var(--color-primary);
  }

  .navbar-toggle {
    display: none;
    justify-self: end;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background: #fff;
    border: 1px solid var(--color-border);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: background var(--transition-fast);
  }

  .navbar-toggle:hover {
    background: var(--color-primary-surface);
  }

  .hamburger {
    display: block;
    width: 20px;
    height: 2px;
    background-color: var(--color-primary);
    position: relative;
    transition: background-color var(--transition-fast);
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 20px;
    height: 2px;
    background-color: var(--color-primary);
    transition: transform var(--transition-base), top var(--transition-base);
  }

  .hamburger::before { top: -6px; }
  .hamburger::after { top: 6px; }

  .navbar-toggle.active .hamburger {
    background-color: transparent;
  }

  .navbar-toggle.active .hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }

  .navbar-toggle.active .hamburger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  @media (max-width: 960px) {
    .navbar-masthead-inner {
      grid-template-columns: 1fr auto;
      min-height: 66px;
    }

    .navbar-logo {
      grid-column: 1;
      justify-self: start;
    }

    .navbar-tip {
      display: none;
    }

    .navbar-toggle {
      display: flex;
    }

    .navbar-nav {
      position: fixed;
      top: 96px;
      left: 0;
      width: 100%;
      background: rgba(255, 255, 255, 0.99);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-lg) 0;
      transform: translateY(-112%);
      opacity: 0;
      visibility: hidden;
      transition: all var(--transition-base);
      box-shadow: var(--shadow-lg);
    }

    .navbar-nav.open {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }

    .navbar-links {
      flex-direction: column;
      align-items: stretch;
      min-height: 0;
      gap: var(--space-xs);
      overflow: visible;
    }

    .navbar-link {
      justify-content: flex-start;
      width: 100%;
      padding: 0.8rem 1rem;
    }
  }

  @media (max-width: 768px) {
    .navbar-top {
      display: none;
    }

    .navbar-masthead-inner {
      min-height: var(--navbar-height);
    }

    .navbar-nav {
      top: var(--navbar-height);
    }

    .logo-mark {
      width: 40px;
      height: 40px;
      box-shadow: 6px 6px 0 var(--color-accent);
    }

    .logo-text {
      font-size: clamp(1.55rem, 8vw, 2.15rem);
    }
  }

  @media (max-width: 430px) {
    .logo-image {
      max-width: 240px;
    }

    .logo-text {
      font-size: 1.42rem;
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const navToggle = document.getElementById('navToggle');
  const navMenu = document.getElementById('navMenu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });

  navToggle?.addEventListener('click', () => {
    navToggle.classList.toggle('active');
    navMenu?.classList.toggle('open');
    const expanded = navToggle.getAttribute('aria-expanded') === 'true';
    navToggle.setAttribute('aria-expanded', String(!expanded));
  });
</script>
