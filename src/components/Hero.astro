---
interface Props {
  data?: any;
}

const d = Astro.props.data || {};
const badge = d.badge || 'Eventos, negócios e oportunidades';
const title = d.title || 'Dê visibilidade ao que merece público';
const subtitle = d.subtitle || 'A Credencial Online divulga eventos, empresas, serviços e iniciativas com linguagem clara e presença profissional.';
const ctaPrimary = d.ctaPrimary || { text: 'Quero divulgar', href: '/contato' };
const ctaSecondary = d.ctaSecondary || { text: 'Ver editorias', href: '/blog' };
const heroImage = d.image || '/images/credencial-hero.svg';
const stats = d.stats || [
  { number: 'Eventos', label: 'agenda e público' },
  { number: 'Negócios', label: 'marca e reputação' },
  { number: 'Divulgação', label: 'estratégia e alcance' },
];
const featured = d.featured || [
  { tag: 'Eventos', title: 'Programe, apresente e comunique com clareza' },
  { tag: 'Negócios', title: 'Mostre diferenciais que geram confiança' },
  { tag: 'Divulgação', title: 'Planeje canais, calendário e mensagem' },
];
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-kicker-row">
      <span class="hero-badge">{badge}</span>
      <span class="hero-dateline">Brasil, eventos, negócios e divulgação</span>
    </div>

    <div class="hero-grid">
      <article class="hero-lead">
        <div class="hero-image-wrap">
          <img class="hero-bg-image" src={heroImage} alt="Painel editorial com calendário de eventos, credenciais e cartões de negócios" width="1600" height="1000" />
          <div class="hero-image-label">Divulgação em foco</div>
        </div>

        <div class="hero-content">
          <h1 class="hero-title">{title}</h1>
          <p class="hero-subtitle">{subtitle}</p>

          <div class="hero-actions">
            <a href={ctaPrimary.href} class="btn btn-primary btn-lg">
              {ctaPrimary.text}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a href={ctaSecondary.href} class="btn btn-outline">
              {ctaSecondary.text}
            </a>
          </div>
        </div>
      </article>

      <aside class="hero-brief" aria-label="Destaques editoriais">
        <p class="hero-brief-label">Radar de oportunidades</p>
        {featured.map((item: any) => (
          <a href="/blog" class="hero-brief-item">
            <span>{item.tag}</span>
            <strong>{item.title}</strong>
          </a>
        ))}
      </aside>
    </div>

    <div class="hero-stats" aria-label="Indicadores da Credencial Online">
      {stats.map((stat: any) => (
        <div class="hero-stat">
          <span class="hero-stat-number">{stat.number}</span>
          <span class="hero-stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 76vh;
    padding-top: calc(var(--navbar-height) + var(--space-xl));
    padding-bottom: var(--space-4xl);
    overflow: hidden;
    background:
      linear-gradient(180deg, #f8fbff 0%, var(--color-bg-cool) 48%, #fff 100%);
  }

  .hero::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: var(--navbar-height);
    height: 5px;
    background: linear-gradient(90deg, var(--color-primary) 0 38%, var(--color-accent) 38% 62%, var(--color-warm) 62% 82%, var(--color-service) 82% 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-kicker-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-xl);
  }

  .hero-badge,
  .hero-dateline {
    font-size: var(--fs-xs);
    font-weight: var(--fw-extrabold);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
  }

  .hero-badge {
    color: var(--color-primary);
  }

  .hero-dateline {
    color: var(--color-text-faint);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: stretch;
  }

  .hero-lead {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(0, 0.82fr);
    gap: var(--space-xl);
    align-items: center;
    padding: var(--space-lg);
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 24px 70px rgba(7, 17, 31, 0.16);
    overflow: hidden;
  }

  .hero-image-wrap {
    position: relative;
    aspect-ratio: 16 / 11;
    width: 100%;
    min-height: 0;
    max-height: 500px;
    overflow: hidden;
    background: var(--color-bg-cool);
    border-radius: var(--radius-xs);
  }

  .hero-bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.02) contrast(1.04);
  }

  .hero-image-label {
    position: absolute;
    left: var(--space-md);
    bottom: var(--space-md);
    padding: 0.45rem 0.7rem;
    background: var(--color-bg-dark);
    color: #fff;
    font-size: var(--fs-xs);
    font-weight: var(--fw-extrabold);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    border-radius: var(--radius-xs);
  }

  .hero-title {
    font-family: var(--font-display);
    max-width: 15ch;
    font-size: clamp(1.55rem, 2.6vw, 2.35rem);
    font-weight: 800;
    line-height: 1.03;
    margin-bottom: var(--space-lg);
    color: var(--color-text);
    overflow-wrap: break-word;
    hyphens: auto;
    animation: fadeInUp 600ms var(--ease-out-expo) 100ms both;
  }

  .hero-title::first-letter {
    color: var(--color-primary);
  }

  .hero-subtitle {
    max-width: 56ch;
    font-size: var(--fs-md);
    color: var(--color-text-secondary);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-xl);
    overflow-wrap: break-word;
    animation: fadeInUp 600ms var(--ease-out-expo) 200ms both;
  }

  .hero-content {
    min-width: 0;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    animation: fadeInUp 600ms var(--ease-out-expo) 300ms both;
  }

  .btn-lg {
    min-height: 50px;
    padding: 0.95rem 1.35rem;
  }

  .hero-brief {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    background: linear-gradient(135deg, var(--color-bg-dark), var(--color-primary) 58%, var(--color-accent));
    color: #fff;
    border-top: 5px solid var(--color-accent);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    animation: scaleIn 800ms var(--ease-out-expo) 250ms both;
  }

  .hero-brief-label {
    grid-column: 1 / -1;
    padding: var(--space-lg) var(--space-lg) var(--space-sm);
    font-size: var(--fs-xs);
    font-weight: var(--fw-extrabold);
    color: #fff4bf;
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
  }

  .hero-brief-item {
    display: block;
    padding: var(--space-lg);
    color: #fff;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .hero-brief-item:hover {
    color: #fff4bf;
    background: rgba(255, 255, 255, 0.06);
  }

  .hero-brief-item span {
    display: block;
    margin-bottom: 0.35rem;
    font-size: var(--fs-xs);
    font-weight: var(--fw-extrabold);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
  }

  .hero-brief-item strong {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    line-height: var(--lh-snug);
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-md);
    margin-top: var(--space-lg);
    animation: fadeInUp 600ms var(--ease-out-expo) 400ms both;
  }

  .hero-stat {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .hero-stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .hero-stat-label {
    display: block;
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    line-height: var(--lh-snug);
    text-align: right;
  }

  @media (max-width: 1120px) {
    .hero-lead {
      grid-template-columns: 1fr;
    }

    .hero-title {
      max-width: 15ch;
    }

    .hero-image-wrap {
      aspect-ratio: 16 / 9;
      min-height: 320px;
      max-height: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: calc(var(--navbar-height) + var(--space-lg));
      padding-bottom: var(--space-3xl);
    }

    .hero-kicker-row {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero-lead {
      padding: var(--space-md);
      gap: var(--space-lg);
    }

    .hero-brief {
      grid-template-columns: 1fr;
    }

    .hero-image-wrap {
      min-height: 220px;
    }

    .hero-title {
      max-width: 100%;
      font-size: clamp(1.4rem, 6.5vw, 1.9rem);
    }

    .hero-stats {
      grid-template-columns: 1fr;
    }

    .hero-stat-label {
      text-align: left;
    }
  }
</style>
