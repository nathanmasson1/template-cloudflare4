{
  "name": "auto-deploy-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run build:client && npm run typecheck",
    "build:client": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply auto-deploy-cloudflare-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply auto-deploy-cloudflare-db --remote"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "hono": "^4.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.14.1"
  }
}
